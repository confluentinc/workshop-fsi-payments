{
  "generators": [
    {
      "name": "customer_profiles_seed",
      "connection": "postgres",
      "table": "riverpay.customer_profiles",
      "localConfigs": {
        "maxEvents": 100,
        "throttleMs": 0
      },
      "row": {
        "customer_id": {
          "_gen": "sequentialString",
          "expr": "CUST-~d",
          "startingFrom": 100000
        },
        "partner_bank_id": {
          "_gen": "oneOf",
          "choices": [
            "BANK-0417",
            "BANK-0082",
            "BANK-1103",
            "BANK-2291",
            "BANK-3308"
          ]
        },
        "segment": {
          "_gen": "oneOf",
          "choices": [
            "retail",
            "small_business",
            "new_partner",
            "wealth"
          ]
        },
        "account_tier": {
          "_gen": "oneOf",
          "choices": [
            "standard",
            "premium",
            "standard",
            "premium",
            "standard"
          ]
        },
        "home_currency": "USD",
        "country": "US",
        "full_name": {
          "_gen": "string",
          "expr": "#{Name.fullName}"
        },
        "tax_id": {
          "_gen": "string",
          "expr": "#{IdNumber.ssnValid}"
        },
        "date_of_birth": {
          "_gen": "string",
          "expr": "#{Date.birthday 'yyyy-MM-dd'}"
        },
        "created_at": {
          "_gen": "now"
        },
        "updated_at": {
          "_gen": "now"
        }
      }
    },

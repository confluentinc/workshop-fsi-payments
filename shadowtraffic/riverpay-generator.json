                "type": "string"
              },
              {
                "name": "destination_account",
                "type": "string"
              },
              {
                "name": "amount",
                "type": "double"
              },
              {
                "name": "currency",
                "type": "string"
              },
              {
                "name": "payment_type",
                "type": "string"
              },
              {
                "name": "channel",
                "type": "string"
              },
              {
                "name": "initiated_at",
                "type": {
                  "type": "long",
                  "logicalType": "timestamp-millis"
                }
              },
              {
                "name": "status",
                "type": "string"
              }
            ]
          }
        }
      }

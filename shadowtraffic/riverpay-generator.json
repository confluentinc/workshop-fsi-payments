    {
      "name": "payment_initiation",
      "connection": "kafka",
      "topic": "riverflow.payments.initiation",
      "vars": {
        "payment_id": {
          "_gen": "sequentialString",
          "expr": "PMT-~d",
          "startingFrom": 202607110000
        },
        "customer_id": {
          "_gen": "lookup",
          "name": "customer_profiles_seed",
          "path": [
            "row",
            "customer_id"
          ]
        },
        "source_account": {
          "_gen": "sequentialString",
          "expr": "ACC-~d",
          "startingFrom": 88000000
        },
        "destination_account": {
          "_gen": "sequentialString",
          "expr": "ACC-~d",
          "startingFrom": 55000000
        },
        "amount": {
          "_gen": "uniformDistribution",
          "bounds": [
            25,
            15000
          ],
          "decimals": 2
        },
        "channel": {
          "_gen": "oneOf",
          "choices": [
            "mobile_app",
            "online_banking",
            "partner_api"
          ]
        }
      },
      "key": {
        "payment_id": {
          "_gen": "var",
          "var": "payment_id"
        }
      },
      "value": {
        "payment_id": {
          "_gen": "var",
          "var": "payment_id"
        },
        "customer_id": {
          "_gen": "var",
          "var": "customer_id"
        },
        "source_account": {
          "_gen": "var",
          "var": "source_account"
        },
        "destination_account": {
          "_gen": "var",
          "var": "destination_account"
        },
        "amount": {
          "_gen": "var",
          "var": "amount"
        },
        "currency": "USD",
        "payment_type": "instant_credit_transfer",
        "channel": {
          "_gen": "var",
          "var": "channel"
        },
        "initiated_at": {
          "_gen": "now"
        },
        "status": "initiated"
      },
      "localConfigs": {
        "throttleMs": 1500,
        "avroSchemaHint": {
          "key": {
            "type": "record",
            "name": "PaymentInitiationKey",
            "namespace": "riverflow.payments",
            "fields": [
              {
                "name": "payment_id",
                "type": "string"
              }
            ]
          },
          "value": {
            "type": "record",
